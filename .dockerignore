# Anything not needed to produce the production image.
# Dockerfile's node stage copies web/ for npm install + build; the go stage
# copies the rest of the source tree. Tests, dev tooling, docs, CI, and the
# local data directory never belong in the build context.

# Version control and IDE
.git
.gitignore
.gitattributes
.github
.vscode
.idea
*.swp
*.swo
.DS_Store

# Claude + agent tooling
.claude
CLAUDE.md

# Developer docs — image page on GHCR uses README.md only
DEVELOPMENT.md
SECURITY.md

# Tests (E2E tests build their own image via testcontainers, not used in prod)
tests
**/*_test.go

# Build artefacts that would otherwise shadow the real build output
build
bin
tmp
data
*.out
*.test

# JS build/test junk that must not cross into the node stage
web/node_modules
web/dist
web/tsconfig.tsbuildinfo
web/coverage
web/.vite
web/.turbo
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/pnpm-debug.log*

# Go workspace files and tool caches
go.work
go.work.sum
vendor
*.exe
*.exe~
*.dll
*.so
*.dylib

# Env files — never bake secrets into an image
.env
.env.*
!.env.example

# Misc
*.log
Makefile
docker/compose.yml
docker/compose.dev.yml
docker/Dockerfile.dev
